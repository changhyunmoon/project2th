# DB 연결 정보
SPRING_DATASOURCE_URL=jdbc:mysql://[RDS주소]:3306/[DB이름]?serverTimezone=Asia/Seoul
SPRING_DATASOURCE_USERNAME=[DB계정명]
SPRING_DATASOURCE_PASSWORD=[DB비밀번호]

# JWT 또는 기타 보안 키
JWT_SECRET=[매우긴임의의문자열]

# OAuth (소셜 로그인) 정보가 있다면
NAVER_CLIENT_ID=[네이버아이디]
NAVER_CLIENT_SECRET=[네이버시크릿]

# 기타 외부 API 키
S3_ACCESS_KEY=[AWS액세스키]
S3_SECRET_KEY=[AWS시크릿키]